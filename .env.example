OPENAI_API_KEY="your_api_key_here"

HUMANCHAT_LLM_MODEL="qwen3.5-flash"
HUMANCHAT_LLM_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"

HUMANCHAT_SPEECH_OUTPUT_PATH="speech/tmp.wav"
HUMANCHAT_SESSION_DIR="data/sessions"
HUMANCHAT_TTS_SERVICE_URL="http://127.0.0.1:9880"
HUMANCHAT_TTS_AUTO_START="false"

# Required only when HUMANCHAT_TTS_AUTO_START=true.
GPT_SOVITS_DIR="path/to/GPT-SoVITS"
GPT_SOVITS_PYTHON="path/to/python.exe"
GPT_SOVITS_API_SCRIPT="api_v2.py"

HUMANCHAT_TTS_REF_AUDIO_PATH="path/to/ref.wav"
HUMANCHAT_TTS_PROMPT_TEXT="でも、怪しい人の手がかりならある。"
HUMANCHAT_TTS_PROMPT_LANG="ja"
HUMANCHAT_TTS_TEXT_LANG="ja"
HUMANCHAT_TTS_SPLIT_METHOD="cut5"
HUMANCHAT_TTS_SPEED_FACTOR="1.0"
